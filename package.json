{
	"name": "dromos",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"biome:format": "biome format",
		"biome:format:fix": "biome format --write",
		"biome:lint": "biome check",
		"biome:lint:fix": "biome check --write",
		"docker:build": "docker compose -f docker/compose.prod.yml --env-file .env.local build",
		"docker:dev": "docker compose -f docker/compose.dev.yml --env-file .env.local up --build --remove-orphans",
		"docker:inspect": "docker inspect dromos:prod --format='{{.Os}}/{{.Architecture}}'",
		"docker:prod": "docker run --env-file .env.production.local -p 3000:3000 dromos:prod",
		"db:format": "npx dotenv-cli -e .env.local -- npx prisma format",
		"db:generate": "npx dotenv-cli -e .env.local -- npx prisma generate",
		"db:migrate:deploy": "npx dotenv-cli -e .env.local -- npx prisma migrate deploy",
		"db:migrate:dev": "npx dotenv-cli -e .env.local -- npx prisma migrate dev",
		"db:push": "npx dotenv-cli -e .env.local -- npx prisma db push",
		"db:reset": "npx dotenv-cli -e .env.local -- npx prisma migrate reset",
		"db:studio": "npx dotenv-cli -e .env.local -- npx prisma studio",
		"stg-db:push": "npx dotenv-cli -e .env.stg.local -- npx prisma db push",
		"stg-db:reset": "npx dotenv-cli -e .env.stg.local -- npx prisma migrate reset",
		"stg-db:studio": "npx dotenv-cli -e .env.stg.local -- npx prisma studio",
		"prod-db:push": "npx dotenv-cli -e .env.production.local -- npx prisma db push",
		"prod-db:reset": "npx dotenv-cli -e .env.production.local -- npx prisma migrate reset",
		"prod-db:studio": "npx dotenv-cli -e .env.production.local -- npx prisma studio"
	},
	"dependencies": {
		"@base-ui/react": "^1.3.0",
		"@better-fetch/fetch": "^1.1.21",
		"@jojojoseph/toon-json-converter": "^2.0.3",
		"@orpc/client": "^1.13.7",
		"@orpc/server": "^1.13.7",
		"@orpc/tanstack-query": "^1.13.7",
		"@prisma/adapter-pg": "^7.5.0",
		"@prisma/client": "^7.5.0",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-query-devtools": "^5.91.3",
		"better-auth": "^1.5.5",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"dotenv": "^17.3.1",
		"framer-motion": "^12.38.0",
		"lucide-react": "^1.7.0",
		"next": "16.1.6",
		"next-themes": "^0.4.6",
		"pg": "^8.20.0",
		"react": "19.2.3",
		"react-dom": "19.2.3",
		"shadcn": "^4.1.1",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"tailwindcss-animate": "^1.0.7",
		"tw-animate-css": "^1.4.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.6",
		"@tailwindcss/postcss": "^4.2.2",
		"@types/node": "^20",
		"@types/pg": "^8.18.0",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"eslint": "^9",
		"eslint-config-next": "16.1.6",
		"prisma": "^7.5.0",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.21.0",
		"typescript": "^5"
	}
}
