// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String           @id
  name           String
  email          String           @unique
  emailVerified  Boolean          @default(false)
  image          String?
  createdAt      DateTime
  updatedAt      DateTime
  sessions       Session[]
  accounts       Account[]
  GearFunctional GearFunctional[]
  GearDevice     GearDevice[]
  Activity       Activity[]
  UserStatistics UserStatistics[]

  workoutPlans   UserWorkoutPlan[]
  WorkoutSession WorkoutSession[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?
}

// --- ENUMS ---
enum FunctionalType {
  ROAD_SHOE // Road shoes
  TRACK_SHOE // Nailed shoe (structure)
  SPIKES_PINS // shoe tacks
  BIKE // Bicycles
  OTHER
}

enum DeviceType {
  SMARTWATCH
  PHONE
  HR_MONITOR
}

model GearFunctional {
  id       String         @id @default(cuid())
  stravaId String?        @unique
  name     String
  type     FunctionalType
  distance Float          @default(0)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Self-relation
  // Allows to link a set of spikes (child) to a spiked shoe (parent)
  parentId String?
  parent   GearFunctional?  @relation("ShoeSpikes", fields: [parentId], references: [id], onDelete: SetNull)
  children GearFunctional[] @relation("ShoeSpikes")

  activities Activity[] @relation("ActivityFunctional")

  // Specific relation to link this gear as "spikes" to activities that used it as such
  activitiesAsSpikes Activity[] @relation("ActivitySpikes")

  @@map("gear_functionals")
}

model GearDevice {
  id   String     @id @default(cuid())
  name String
  type DeviceType

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  activities Activity[]

  @@map("gear_devices")
}

model Activity {
  id                 String   @id @default(cuid()) // Internal ID
  stravaId           String   @unique
  name               String
  distance           Float // Meters
  movingTime         Int // Seconds
  elapsedTime        Int // Seconds
  totalElevationGain Float // Meters
  type               String // Ex. "Run", "Ride"
  sportType          String // Ex. "TrackRun", "TrailRun"
  startDate          DateTime // ISO 8601 translated to DateTime
  averageHeartrate   Float?
  sufferScore        Float?

  // Compliance fields
  rawJson   Json? // Raw Strava API response; nullified after 7 days
  isPurged  Boolean  @default(false) // True once rawJson has been purged
  createdAt DateTime @default(now()) // When this record was synced

  // user relationship
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Gear relationships
  functionalId   String?
  functionalGear GearFunctional? @relation("ActivityFunctional", fields: [functionalId], references: [id], onDelete: SetNull)

  deviceId String?
  device   GearDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  // Spike relationship (specific to track activities)
  spikesId String?
  spikes   GearFunctional? @relation("ActivitySpikes", fields: [spikesId], references: [id], onDelete: SetNull)

  @@map("activities")
}

model UserStatistics {
  id String @id @default(cuid())

  sport_name   String
  terrain_type String

  total_distance_km Float @default(0)
  total_time_min    Int   @default(0) // Stored in seconds (field name is misleading; do not convert)
  total_elevation_m Int   @default(0)
  sessions_count    Int   @default(0)

  // Records
  max_distance_km Float @default(0)
  max_elevation_m Int   @default(0)

  // Timestamps
  last_activity_date DateTime
  updated_at         DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sport_name, terrain_type])
  @@map("user_statistics")
}

// ==========================================
// DROMOS - ENGINE ROOM
// ==========================================

model UserWorkoutPlan {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name       String
  type       String // es. Ipertrofia, Forza
  expiryDate DateTime? // Opzionale, nel caso non ci sia scadenza fissa

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  days WorkoutDay[]

  @@map("user_workout_plans")
}

model WorkoutDay {
  id     String          @id @default(cuid())
  planId String
  plan   UserWorkoutPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  name  String // es. Martedì
  order Int
  notes String? @db.Text

  exercises      UserExercise[]
  WorkoutSession WorkoutSession[]

  @@map("workout_days")
}

model UserExercise {
  id    String     @id @default(cuid())
  dayId String
  day   WorkoutDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  // Relazione esercizio primario
  exerciseId String
  exercise   Exercise @relation("PrimaryExercise", fields: [exerciseId], references: [id], onDelete: Restrict)

  // Relazione esercizio alternativo (opzionale)
  alternativeExerciseId String?
  alternativeExercise   Exercise? @relation("AlternativeExercise", fields: [alternativeExerciseId], references: [id], onDelete: SetNull)

  order    Int
  restTime Int? // In secondi

  // Gestione Superset
  supersetId    String? // Raggruppa gli esercizi della stessa superserie
  supersetOrder Int? // Ordine interno alla superserie

  // Note
  coachNotes    String? @db.Text
  personalNotes String? @db.Text

  // Impostazioni specifiche attrezzatura (UI)
  equipmentSetting1 String?
  equipmentSetting2 String?

  reps            ExerciseRep[]
  SessionExercise SessionExercise[]

  @@map("user_exercises")
}

model ExerciseRep {
  id             String       @id @default(cuid())
  userExerciseId String
  userExercise   UserExercise @relation(fields: [userExerciseId], references: [id], onDelete: Cascade)

  setNumber  Int
  targetReps String? // es. "8-12", "MAX"
  targetRpe  Float? // Usa Float per evitare i conflitti di serializzazione di Decimal in Next.js

  weight      Float?
  machineType String? // es. Cavi Doppi

  @@map("exercise_reps")
}

model Exercise {
  id            String      @id @default(cuid())
  muscleGroupId String
  muscleGroup   MuscleGroup @relation(fields: [muscleGroupId], references: [id], onDelete: Restrict)

  externalId String? // ID di ExerciseDB
  nameEng    String
  nameIta    String?
  photoUrl   String?

  // Embedding locale per la ricerca vettoriale (Se usi pgvector)
  // Decommenta e adatta la riga sotto quando configuri gli embedding
  // embedding    Unsupported("vector(768)")?

  primaryUsages   UserExercise[]    @relation("PrimaryExercise")
  alternateUsages UserExercise[]    @relation("AlternativeExercise")
  SessionExercise SessionExercise[]

  @@map("exercises")
}

model MuscleGroup {
  id   String @id @default(cuid())
  name String

  exercises Exercise[]

  @@map("muscle_groups")
}

// ==========================================
// DROMOS - WORKOUT LOGGING (STORICO)
// ==========================================

model WorkoutSession {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Riferimento al giorno della scheda (opzionale, così se cancella la scheda non perde lo storico)
  dayId String?
  day   WorkoutDay? @relation(fields: [dayId], references: [id], onDelete: SetNull)

  startTime    DateTime  @default(now())
  endTime      DateTime?
  sessionNotes String?   @db.Text

  exercises SessionExercise[]

  @@map("workout_sessions")
}

model SessionExercise {
  id        String         @id @default(cuid())
  sessionId String
  session   WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  // Riferimento al piano (per sapere da quale riga della scheda deriva)
  userExerciseId String?
  userExercise   UserExercise? @relation(fields: [userExerciseId], references: [id], onDelete: SetNull)

  // L'esercizio EFFETTIVAMENTE svolto (fondamentale se ha usato l'alternativa)
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  order Int

  sets SessionSet[]

  @@map("session_exercises")
}

model SessionSet {
  id                String          @id @default(cuid())
  sessionExerciseId String
  sessionExercise   SessionExercise @relation(fields: [sessionExerciseId], references: [id], onDelete: Cascade)

  setNumber Int

  // Qui salviamo i dati REALI, quindi 'reps' è un numero (quante ne ha fatte), non un range
  reps        Int
  weight      Float?
  rpe         Float?
  machineType String?

  @@map("session_sets")
}
